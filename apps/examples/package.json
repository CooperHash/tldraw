{
	"name": "mermaid-canvas",
	"description": "Minimal Mermaid diagram canvas.",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "vite --host",
		"preview": "vite preview --host",
		"build": "vite build",
		"lint": "yarn run -T tsx ../../internal/scripts/lint.ts",
