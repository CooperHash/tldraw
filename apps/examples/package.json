		"tldraw": "workspace:*",
		"vite": "^8.0.16"
	},
	"devDependencies": {
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"vitest": "^4.1.7"
	},
	"type": "module"
}
