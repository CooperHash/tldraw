{
	"name": "@tldraw/monorepo",
	"description": "tldraw infinite canvas SDK (monorepo).",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "tldraw Inc.",
		"email": "hello@tldraw.com"
	},
	"homepage": "https://tldraw.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/tldraw/tldraw"
	},
	"bugs": {
		"url": "https://github.com/tldraw/tldraw/issues"
	},
	"keywords": [
		"tldraw",
		"sdk",
		"drawing",
		"app",
		"development",
		"whiteboard",
		"canvas",
		"infinite"
	],
	"workspaces": [
		"apps/examples",
		"packages/editor",
		"packages/mermaid",
		"packages/state",
		"packages/state-react",
		"packages/store",
		"packages/tldraw",
		"packages/tlschema",
		"packages/utils",
		"packages/validate"
	],
	"scripts": {
		"clean": "internal/scripts/clean.sh",
		"postinstall": "yarn workspace tldraw predev",
		"dev": "yarn workspace tldraw predev && yarn workspace mermaid-canvas dev",
		"build": "yarn workspace tldraw prebuild && yarn workspace mermaid-canvas build",
		"build-app": "yarn build",
		"build-package": "yarn workspaces foreach -A --include '@tldraw/*' --include tldraw run build",
		"preview-examples": "yarn build && cd apps/examples && yarn preview",
		"lint": "tsx internal/scripts/lint.ts",
		"format": "tsx internal/scripts/lint.ts --fix",
		"format-current": "tsx internal/scripts/lint.ts --fix --current",
		"lint-current": "tsx internal/scripts/lint.ts --current",
		"typecheck": "tsx internal/scripts/typecheck.ts",
		"check-packages": "tsx internal/scripts/check-packages.ts",
		"check-circular-deps": "tsx internal/scripts/check-circular-deps.ts",
		"test-ci": "yarn vitest run",
		"test": "yarn vitest",
		"test-coverage": "yarn vitest run --coverage && open-cli coverage/index.html"
	},
	"engines": {
		"npm": ">=7.0.0",
		"node": ">=22.12.0"
	},
	"packageManager": "yarn@4.12.0",
	"lint-staged": {
		"*.{js,jsx,ts,tsx,cjs,mjs}": [
			"oxfmt --no-error-on-unmatched-pattern",
			"oxlint"
		],
		"*.{css,md,mdx,html,yml,yaml}": [
			"oxfmt --no-error-on-unmatched-pattern"
		]
	},
	"devDependencies": {
		"@microsoft/api-extractor": "^7.55.2",
		"@types/node": "^22.15.31",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260129.1",
		"@vitest/coverage-v8": "^4.1.7",
		"@vitest/ui": "^4.1.7",
		"@yarnpkg/types": "^4.0.0",
		"ast-types": "^0.14.2",
		"esbuild": "^0.28.0",
		"glob": "^13.0.0",
		"is-ci": "^3.0.1",
		"jsdom": "^29.1.1",
		"json5": "^2.2.3",
		"kleur": "^4.1.5",
		"lazyrepo": "0.0.0-alpha.27",
		"lint-staged": "^15.4.3",
		"open-cli": "^8.0.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.66.0",
		"oxlint-tsgolint": "^0.23.0",
		"recast": "^0.22.0",
		"rimraf": "^4.4.1",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3",
		"vite-plugin-circular-dependency": "^0.5.0",
		"vitest": "^4.1.7",
		"vitest-canvas-mock": "^1.1.3"
	},
	"resolutions": {
		"tldraw": "workspace:packages/tldraw",
		"@tldraw/editor": "workspace:packages/editor",
		"@tldraw/mermaid": "workspace:packages/mermaid",
		"@tldraw/state": "workspace:packages/state",
		"@tldraw/state-react": "workspace:packages/state-react",
		"@tldraw/store": "workspace:packages/store",
		"@tldraw/tlschema": "workspace:packages/tlschema",
		"@tldraw/utils": "workspace:packages/utils",
		"@tldraw/validate": "workspace:packages/validate",
		"@microsoft/tsdoc@npm:~0.15.1": "patch:@microsoft/tsdoc@npm%3A0.15.1#~/.yarn/patches/@microsoft-tsdoc-npm-0.15.1-e24295d9bd.patch",
		"@microsoft/tsdoc@npm:0.15.1": "patch:@microsoft/tsdoc@npm%3A0.15.1#~/.yarn/patches/@microsoft-tsdoc-npm-0.15.1-e24295d9bd.patch",
		"@types/node": "^22.15.31"
	}
}
